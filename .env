# Local dev: leave API base empty so fetch uses /api/website-briefs on :3000
# and Create React App "proxy" (package.json) forwards to Laravel on :8000.
# You will see the request in Network as localhost:3000 → /api/website-briefs.
#
# Optional full URL (overrides everything):
# REACT_APP_WEBSITE_BRIEF_URL=http://127.0.0.1:8000/api/website-briefs
#
# Production: set origin only (no trailing slash), e.g. https://your-laravel-domain.com
# REACT_APP_API_BASE_URL=https://your-laravel-domain.com
REACT_APP_API_BASE_URL=http://127.0.0.1:8000/admin

REACT_APP_STRIPE_KEY=pk_test_51KP84pD81cY9MMI1fQoq2bqzaxCYZfIGKd8PXMlvZitVlE4O1lENtGWgIG6KkoMwkqWxjGBnlsvLvDBsd4lCPmgZ00bB7Be6iw
REACT_APP_PAYPAL_CLIENT_ID=ATR1igiNkqRc5NLq0ujblPqgJr08xigsWKgZW9BEKN71ehU1xmQv6gnqwJQB3XpLgvs588b_VJeRmjJk

# With package.json "proxy", CRA may set allowedHosts to your LAN IP; if that is
# missing/invalid, webpack-dev-server errors. Dev only.
DANGEROUSLY_DISABLE_HOST_CHECK=true
